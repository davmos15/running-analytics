# Data source: activities are synced from Garmin Connect into Firestore by the
# server-side job in scripts/ (see requirements-garmin.txt). No browser-facing
# Garmin credentials are needed here.

# Firebase Configuration
REACT_APP_FIREBASE_API_KEY=your_firebase_api_key_here
REACT_APP_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your_project_id_here
REACT_APP_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
REACT_APP_FIREBASE_APP_ID=your_app_id_here

# App Configuration
REACT_APP_APP_NAME=Running Analytics
REACT_APP_VERSION=1.0.0